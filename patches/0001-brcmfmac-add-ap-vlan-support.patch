+static int brcmf_vlan_del_vif(struct wiphy *wiphy, struct wireless_dev *wdev)
+{
+	struct net_device *ndev = wdev->netdev;
+	struct brcmf_if *ifp = netdev_priv(ndev);
+	struct brcmf_if *parent_ifp = ifp->parent_ifp;
+
+	if (!IS_ENABLED(CONFIG_BRCMFMAC_AP_VLAN))
+		return -EOPNOTSUPP;
+
+	brcmf_dbg(INFO, "Removing AP_VLAN %s\n", ndev->name);
+
+	if (parent_ifp)
+		brcmf_vlan_unmap_all(parent_ifp, ndev);
+
+	ndev->netdev_ops->ndo_stop(ndev);
+	brcmf_net_detach(ndev, true);
+
+	return 0;
+}
+
+static void brcmf_vlan_teardown_all(struct wiphy *wiphy,
+				    struct brcmf_if *ap_ifp)
+{
+	struct brcmf_cfg80211_info *cfg = wiphy_to_cfg(wiphy);
+	struct brcmf_cfg80211_vif *vlan_vif, *tmp;
+
+	list_for_each_entry_safe(vlan_vif, tmp, &cfg->vif_list, list) {
+		if (vlan_vif->wdev.iftype == NL80211_IFTYPE_AP_VLAN &&
+		    vlan_vif->ifp->parent_ifp == ap_ifp)
+			brcmf_vlan_del_vif(wiphy, &vlan_vif->wdev);
+	}
+	brcmf_vlan_map_destroy(ap_ifp);
+}
