+static struct wireless_dev *brcmf_vlan_add_vif(struct wiphy *wiphy,
+					       const char *name)
+{
+	struct brcmf_cfg80211_info *cfg = wiphy_to_cfg(wiphy);
+	struct brcmf_cfg80211_vif *vif, *ap_vif;
+	struct net_device *ndev;
+	struct brcmf_if *ifp, *parent_ifp = NULL;
+	int err;
+
+	if (!IS_ENABLED(CONFIG_BRCMFMAC_AP_VLAN))
+		return ERR_PTR(-EOPNOTSUPP);
+
+	/* Find a running AP interface to be the parent */
+	list_for_each_entry(ap_vif, &cfg->vif_list, list) {
+		if (ap_vif->wdev.iftype == NL80211_IFTYPE_AP &&
+		    test_bit(BRCMF_VIF_STATUS_AP_CREATED, &ap_vif->sme_state)) {
+			parent_ifp = ap_vif->ifp;
+			break;
+		}
+	}
 
+	if (!parent_ifp) {
+		brcmf_err("Cannot add AP_VLAN: no active AP interface\n");
+		return ERR_PTR(-ENOENT);
+	}
+
+	/* Lazily init the STA-VLAN hash table on the parent AP */
+	if (!parent_ifp->sta_vlan_map_init) {
+		err = brcmf_vlan_map_init(parent_ifp);
+		if (err)
+			return ERR_PTR(err);
+	}
+
+	vif = brcmf_alloc_vif(cfg, NL80211_IFTYPE_AP_VLAN);
+	if (IS_ERR(vif))
+		return (struct wireless_dev *)vif;
+
+	ndev = alloc_netdev(sizeof(*ifp), name, NET_NAME_UNKNOWN, ether_setup);
+	if (!ndev) {
+		err = -ENOMEM;
+		goto err_free_vif;
+	}
+
+	ndev->ieee80211_ptr = &vif->wdev;
+	ndev->needs_free_netdev = true;
+	ndev->priv_destructor = brcmf_cfg80211_free_netdev;
+	SET_NETDEV_DEV(ndev, wiphy_dev(cfg->wiphy));
+
+	eth_hw_addr_set(ndev, parent_ifp->mac_addr);
+
+	ifp = netdev_priv(ndev);
+	ifp->vif = vif;
+	ifp->ndev = ndev;
+	ifp->drvr = cfg->pub;
+	ifp->parent_ifp = parent_ifp;
+	ifp->ifidx = parent_ifp->ifidx;
+	ifp->bsscfgidx = parent_ifp->bsscfgidx;
+
+	vif->ifp = ifp;
+	vif->wdev.netdev = ndev;
+
+	err = brcmf_net_vlan_attach(ifp);
+	if (err) {
+		brcmf_err("Failed to attach %s device\n", ndev->name);
+		free_netdev(ndev);
+		return ERR_PTR(err);
+	}
+
+	brcmf_dbg(INFO, "AP_VLAN %s created (parent %s)\n",
+		  ndev->name, parent_ifp->ndev->name);
+
+	return &vif->wdev;
+
+err_free_vif:
+	brcmf_free_vif(vif);
+	return ERR_PTR(err);
+}
