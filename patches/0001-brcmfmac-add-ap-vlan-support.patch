+static int brcmf_vlan_del_vif(struct wiphy *wiphy, struct wireless_dev *wdev)
+{
+	struct net_device *ndev = wdev->netdev;
+	struct brcmf_if *ifp = netdev_priv(ndev);
+	struct brcmf_if *parent_ifp = ifp->parent_ifp;
+
+	brcmf_dbg(INFO, "Removing AP_VLAN %s\n", ndev->name);
+
+	/* Remove all STA mappings pointing to this VLAN */
+	if (parent_ifp)
+		brcmf_vlan_unmap_all(parent_ifp, ndev);
+
+	ndev->netdev_ops->ndo_stop(ndev);
+	brcmf_net_detach(ndev, true);
+
+	return 0;
+}
