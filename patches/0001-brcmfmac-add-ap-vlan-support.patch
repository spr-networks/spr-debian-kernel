+static netdev_tx_t brcmf_net_vlan_start_xmit(struct sk_buff *skb,
+					      struct net_device *ndev)
+{
+	struct brcmf_if *ifp = netdev_priv(ndev);
+	struct brcmf_if *parent_ifp = ifp->parent_ifp;
+	struct brcmf_pub *drvr;
+	struct ethhdr *eh;
+	int head_delta;
+	unsigned int tx_bytes = skb->len;
+	int ret;
+
+	if (!parent_ifp) {
+		dev_kfree_skb(skb);
+		ndev->stats.tx_dropped++;
+		return NETDEV_TX_OK;
+	}
+
+	drvr = parent_ifp->drvr;
+
+	if (drvr->bus_if->state != BRCMF_BUS_UP) {
+		dev_kfree_skb(skb);
+		ndev->stats.tx_dropped++;
+		return NETDEV_TX_OK;
+	}
+
+	if (!drvr->settings->iapp && brcmf_skb_is_iapp(skb)) {
+		dev_kfree_skb(skb);
+		ndev->stats.tx_dropped++;
+		return NETDEV_TX_OK;
+	}
+
+	/* Ensure headroom for protocol header */
+	if (skb_headroom(skb) < drvr->hdrlen || skb_header_cloned(skb)) {
+		head_delta = max_t(int, drvr->hdrlen - skb_headroom(skb), 0);
+		ret = pskb_expand_head(skb, ALIGN(head_delta, NET_SKB_PAD), 0,
+				       GFP_ATOMIC);
+		if (ret < 0) {
+			dev_kfree_skb(skb);
+			ndev->stats.tx_dropped++;
+			return NETDEV_TX_OK;
+		}
+	}
+
+	if (skb->len < sizeof(*eh)) {
+		dev_kfree_skb(skb);
+		ndev->stats.tx_dropped++;
+		return NETDEV_TX_OK;
+	}
+
+	eh = (struct ethhdr *)(skb->data);
+	if (eh->h_proto == htons(ETH_P_PAE))
+		atomic_inc(&parent_ifp->pend_8021x_cnt);
+
+	if ((skb->priority == 0) || (skb->priority > 7))
+		skb->priority = cfg80211_classify8021d(skb, NULL);
+
+	sk_pacing_shift_update(skb->sk, 8);
+
+	/* Send through the parent AP's firmware interface */
+	ret = brcmf_proto_tx_queue_data(drvr, parent_ifp->ifidx, skb);
+	if (ret < 0) {
+		brcmf_txfinalize(parent_ifp, skb, false);
+		ndev->stats.tx_dropped++;
+	} else {
+		ndev->stats.tx_packets++;
+		ndev->stats.tx_bytes += tx_bytes;
+	}
+
+	return NETDEV_TX_OK;
+}
+
+static const struct net_device_ops brcmf_netdev_ops_vlan = {
+	.ndo_open = brcmf_net_vlan_open,
+	.ndo_stop = brcmf_net_vlan_stop,
+	.ndo_start_xmit = brcmf_net_vlan_start_xmit,
+};
+
+int brcmf_net_vlan_attach(struct brcmf_if *ifp)
+{
+	struct brcmf_pub *drvr = ifp->drvr;
+	struct net_device *ndev = ifp->ndev;
+	int err;
+
+	brcmf_dbg(TRACE, "Enter (AP_VLAN %s)\n", ndev->name);
+
+	ndev->netdev_ops = &brcmf_netdev_ops_vlan;
+	ndev->needed_headroom += drvr->hdrlen;
+
+	err = cfg80211_register_netdevice(ndev);
+	if (err)
+		bphy_err(drvr, "Failed to register %s device\n", ndev->name);
+
+	return err;
+}
