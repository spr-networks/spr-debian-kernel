+void brcmf_vlan_map_destroy(struct brcmf_if *ifp)
+{
+	if (!READ_ONCE(ifp->sta_vlan_map_init))
+		return;
+	/* Prevent new RX lookups before tearing down the table */
+	WRITE_ONCE(ifp->sta_vlan_map_init, false);
+	synchronize_rcu();
+	rhashtable_free_and_destroy(&ifp->sta_vlan_map,
+				    brcmf_sta_vlan_entry_free, NULL);
+}
+
+int brcmf_vlan_map_sta(struct brcmf_if *parent_ifp, const u8 *mac,
+		       struct net_device *vlan_ndev)
+{
+	struct brcmf_sta_vlan_entry *entry, *old;
+
+	if (!READ_ONCE(parent_ifp->sta_vlan_map_init))
+		return -ENOENT;
+
+	entry = kzalloc(sizeof(*entry), GFP_KERNEL);
+	if (!entry)
+		return -ENOMEM;
+
+	ether_addr_copy(entry->mac, mac);
+	entry->vlan_ndev = vlan_ndev;
+
+	old = rhashtable_lookup_get_insert_fast(&parent_ifp->sta_vlan_map,
+						&entry->rhash,
+						brcmf_sta_vlan_params);
+	if (IS_ERR(old)) {
+		kfree(entry);
+		return PTR_ERR(old);
+	}
+	if (old) {
+		/* Replace existing mapping */
+		rhashtable_remove_fast(&parent_ifp->sta_vlan_map,
+				       &old->rhash, brcmf_sta_vlan_params);
+		kfree_rcu(old, rcu);
+	}
+
+	return 0;
+}
+
+void brcmf_vlan_unmap_sta(struct brcmf_if *parent_ifp, const u8 *mac)
+{
+	struct brcmf_sta_vlan_entry *entry;
+	int err;
+
+	if (!READ_ONCE(parent_ifp->sta_vlan_map_init))
+		return;
+
+	rcu_read_lock();
+	entry = rhashtable_lookup(&parent_ifp->sta_vlan_map, mac,
+				  brcmf_sta_vlan_params);
+	if (entry) {
+		err = rhashtable_remove_fast(&parent_ifp->sta_vlan_map,
+					     &entry->rhash,
+					     brcmf_sta_vlan_params);
+		rcu_read_unlock();
+		if (!err)
+			kfree_rcu(entry, rcu);
+	} else {
+		rcu_read_unlock();
+	}
+}
+
+void brcmf_vlan_unmap_all(struct brcmf_if *parent_ifp,
+			  struct net_device *vlan_ndev)
+{
+	struct rhashtable_iter iter;
+	struct brcmf_sta_vlan_entry *entry;
+
+	if (!READ_ONCE(parent_ifp->sta_vlan_map_init))
+		return;
+
+	rhashtable_walk_enter(&parent_ifp->sta_vlan_map, &iter);
+	rhashtable_walk_start(&iter);
+
+	while ((entry = rhashtable_walk_next(&iter)) != NULL) {
+		if (IS_ERR(entry))
+			continue;
+		if (entry->vlan_ndev == vlan_ndev) {
+			rhashtable_remove_fast(&parent_ifp->sta_vlan_map,
+					       &entry->rhash,
+					       brcmf_sta_vlan_params);
+			kfree_rcu(entry, rcu);
+		}
+	}
+
+	rhashtable_walk_stop(&iter);
+	rhashtable_walk_exit(&iter);
+}
+
+struct net_device *brcmf_vlan_lookup_sta(struct brcmf_if *ifp, const u8 *mac)
+{
+	struct brcmf_sta_vlan_entry *entry;
+
+	if (!READ_ONCE(ifp->sta_vlan_map_init))
+		return NULL;
+
+	entry = rhashtable_lookup(&ifp->sta_vlan_map, mac,
+				  brcmf_sta_vlan_params);
+	return entry ? entry->vlan_ndev : NULL;
+}
